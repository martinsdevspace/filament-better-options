{
  "name": "martinsdevspace/filament-better-options",
  "description": "Filament form components for better radio and checkbox options.",
  "type": "library",
  "keywords": [
    "checkbox",
    "filament",
    "forms",
    "laravel",
    "plugin",
    "php",
    "tonegabes"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "filament/forms": "^5.0",
    "spatie/laravel-package-tools": "^1.15.0",
    "tonegabes/filament-phosphor-icons": "^1.3"
  },
  "require-dev": {
    "laravel/pint": "^1.0",
    "larastan/larastan": "^3.0",
    "phpstan/phpstan-deprecation-rules": "^2.0",
    "friendsofphp/php-cs-fixer": "^3.86"
  },
  "autoload": {
    "psr-4": {
      "ToneGabes\\BetterOptions\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ToneGabes\\BetterOptions\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "analyze": "vendor/bin/phpstan analyze",
    "format": "vendor/bin/pint"
  },
  "extra": {
    "laravel": {
      "providers": [
        "ToneGabes\\BetterOptions\\BetterOptionsServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
